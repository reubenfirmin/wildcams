# Wildcams Configuration

# Directory where downloaded videos will be stored
VIDEO_DIR=/home/rfirmin/Videos/wildcams

# Optional: Specific video file extensions to look for (comma-separated)
VIDEO_EXTENSIONS=mp4,mov,avi,mkv,m4v

# Optional: SD card mount point base (will create subdirs as needed)
MOUNT_BASE=/tmp/wildcams_mounts

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Video processing configuration
# Process every Nth frame (higher = faster but less thorough)
FRAME_SKIP=30

# Minimum confidence threshold for animal detection (0.0-1.0)  
CONFIDENCE_THRESHOLD=0.1

# Maximum frames to analyze per video (to control processing time)
MAX_FRAMES_PER_VIDEO=20

# Clustering parameters
# DBSCAN epsilon (lower = stricter clustering, higher = looser clustering)
CLUSTERING_EPS=0.3

# Minimum samples per cluster
MIN_SAMPLES=2

# Animal detection validation thresholds
# MegaDetector confidence threshold for strong evidence
MEGADETECTOR_HIGH_CONFIDENCE=0.6

# YOLO confidence threshold for medium evidence  
YOLO_HIGH_CONFIDENCE=0.7

# Minimum YOLO detections needed for medium evidence
MIN_YOLO_DETECTIONS=8

# Average confidence threshold for weak evidence
WEAK_EVIDENCE_THRESHOLD=0.4

# Wildlife-specific model confidence threshold (lower since they're specialized)
WILDLIFE_MODEL_CONFIDENCE=0.2

# Camera handling detection (equipment false positive filtering)
# Detection density threshold (detections per frame) - higher suggests camera handling
DETECTION_DENSITY_THRESHOLD=15.0

# Low confidence mass threshold - if >X% of detections are low confidence, likely equipment
LOW_CONFIDENCE_RATIO_THRESHOLD=0.7

# Low confidence cutoff 
LOW_CONFIDENCE_CUTOFF=0.2