# direnv configuration for wildcams project

# Suppress direnv export output (must be first)
export DIRENV_LOG_FORMAT=""

# Set up project-specific environment variables
export PROJECT_ROOT="$(pwd)"
export PROJECT_NAME="wildcams"

# Load .env file if it exists
dotenv_if_exists .env

# Ensure uv is available
if ! command -v uv &> /dev/null; then
    echo "⚠️  uv not found in PATH. Install with: curl -LsSf https://astral.sh/uv/install.sh | sh"
fi

# Add project scripts to PATH so you can run them directly
PATH_add "$PROJECT_ROOT"

# SD Card watcher background process management
export WATCHER_PID_FILE="$PROJECT_ROOT/.sd_watcher.pid"
export WATCHER_LOG_FILE="$PROJECT_ROOT/.sd_watcher.log"

# Check watcher status (but don't auto-start)
if [[ -f "$WATCHER_PID_FILE" ]]; then
    local pid=$(cat "$WATCHER_PID_FILE" 2>/dev/null)
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        echo "✅ SD card watcher running (PID: $pid)"
    else
        echo "💤 SD card watcher not running"
        echo "▶️  Start with: ./watch.sh"
    fi
else
    echo "💤 SD card watcher not running"
    echo "▶️  Start with: ./watch.sh"
fi

# Example: Set CUDA/GPU environment variables (uncomment if needed for ML/camera work)
# export CUDA_VISIBLE_DEVICES="0"
# export PYTORCH_CUDA_ALLOC_CONF="max_split_size_mb:512"

# Example: Database connection (uncomment and modify as needed)
# export DATABASE_URL="postgresql://localhost:5432/wildcams_dev"

# Example: API keys and configuration (use .env file for sensitive data)
# export API_ENV="development"