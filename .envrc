# direnv configuration for wildcams project

# Suppress direnv export output (must be first)
export DIRENV_LOG_FORMAT=""

# Use Nix flake for development environment
use flake 2>/dev/null || use flake

# Set up project-specific environment variables
export PROJECT_ROOT="$(pwd)"
export PROJECT_NAME="wildcams"

# Add local bin directory to PATH if it exists
PATH_add bin

# Load .env file if it exists
dotenv_if_exists .env

# uv will manage Python virtual environment
export UV_PROJECT_ENVIRONMENT=".venv"

# SD Card watcher background process management
export WATCHER_PID_FILE="$PROJECT_ROOT/.sd_watcher.pid"
export WATCHER_LOG_FILE="$PROJECT_ROOT/.sd_watcher.log"

# Start SD card watcher when entering directory (non-blocking)
if [[ ! -f "$WATCHER_PID_FILE" ]]; then
    echo "🎥 Starting SD card watcher daemon..."
    # Start daemon - it will fork itself and the parent will exit immediately
    "$PROJECT_ROOT/sd_watcher.py" --daemon --pid-file "$WATCHER_PID_FILE" --log-file "$WATCHER_LOG_FILE" &
    local start_pid=$!
    
    # Wait briefly for daemon to start and write PID file
    sleep 0.5
    # Don't wait for parent process - let it exit naturally
    
    if [[ -f "$WATCHER_PID_FILE" ]]; then
        local pid=$(cat "$WATCHER_PID_FILE")
        echo "✅ SD card watcher started (PID: $pid)"
        echo "📋 Watch activity: tail -f $WATCHER_LOG_FILE"
        echo "🛑 Stop with: bash $PROJECT_ROOT/stop_watcher.sh $PROJECT_ROOT"
    else
        echo "❌ Failed to start daemon"
    fi
else
    local pid=$(cat "$WATCHER_PID_FILE" 2>/dev/null)
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        echo "✅ SD card watcher already running (PID: $pid)"
        echo "📋 Watch activity: tail -f $WATCHER_LOG_FILE"
        echo "🛑 Stop with: bash $PROJECT_ROOT/stop_watcher.sh $PROJECT_ROOT"
    else
        echo "🔄 Restarting stale watcher..."
        rm -f "$WATCHER_PID_FILE"
        "$PROJECT_ROOT/sd_watcher.py" --daemon --pid-file "$WATCHER_PID_FILE" --log-file "$WATCHER_LOG_FILE" &
        local start_pid=$!
        sleep 0.5
        # Don't wait for parent process - let it exit naturally
        
        if [[ -f "$WATCHER_PID_FILE" ]]; then
            local new_pid=$(cat "$WATCHER_PID_FILE")
            echo "✅ SD card watcher restarted (PID: $new_pid)"
        fi
    fi
fi

# Example: Set CUDA/GPU environment variables (uncomment if needed for ML/camera work)
# export CUDA_VISIBLE_DEVICES="0"
# export PYTORCH_CUDA_ALLOC_CONF="max_split_size_mb:512"

